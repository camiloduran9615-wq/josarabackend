# ── Branding de Plataforma (single source of truth: config/platform.php) ──────
# Para renombrar la plataforma cambia SOLO estas variables — no se toca código.
APP_NAME="JOSARA CLOUD"
APP_SHORT_NAME="JOSARA"
APP_TAGLINE="Confianza y precisión en cada número."
APP_DESCRIPTION="ERP Contable SaaS Multiempresa"
APP_COMPANY="JOSARA CLOUD"
APP_SUPPORT_EMAIL=soporte@josara.cloud
APP_WEBSITE=https://josara.cloud
APP_FRONTEND_URL=http://localhost:3001
APP_VERSION=1.0.0
# Activos visuales (rutas públicas servidas desde backend/public).
APP_LOGO_LIGHT=/logo_claro.png
APP_LOGO_DARK=/logo_oscuro.png
APP_FAVICON=/favicon.ico
APP_PRIMARY_COLOR="#0D1B2A"
APP_SECONDARY_COLOR="#D4AF37"
APP_COPYRIGHT="© JOSARA CLOUD"

# ── Administradores globales del Operations Control Center ────────────────
PLATFORM_ADMIN_1_NAME="SaaS Root"
PLATFORM_ADMIN_1_EMAIL=admin1@josara.cloud
PLATFORM_ADMIN_1_PASSWORD="ChangeMe123!"
PLATFORM_ADMIN_1_ROLE=super_admin
PLATFORM_ADMIN_1_ACTIVE=true

PLATFORM_ADMIN_2_NAME="Support Ops"
PLATFORM_ADMIN_2_EMAIL=support1@josara.cloud
PLATFORM_ADMIN_2_PASSWORD="ChangeMe123!"
PLATFORM_ADMIN_2_ROLE=support_admin
PLATFORM_ADMIN_2_ACTIVE=true

APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ── Branding expuesto al frontend (Vite) ────────────────────────────────────
# NOTA: el frontend es un proyecto Vite separado (carpeta frontend/) y lee su
# propio .env. Estas variables se documentan aquí como contrato; los valores
# efectivos del build viven en frontend/.env.* (ver frontend/.env.example).
VITE_APP_NAME="${APP_NAME}"
VITE_APP_SHORT_NAME="${APP_SHORT_NAME}"
VITE_APP_TAGLINE="${APP_TAGLINE}"
VITE_APP_DESCRIPTION="${APP_DESCRIPTION}"
VITE_APP_VERSION="${APP_VERSION}"


# DANE / DIVIPOLA official municipality catalog synchronization
# Configure an official HTTPS JSON/CSV source from dane.gov.co or datos.gov.co.
DANE_DIVIPOLA_URL=https://geoportal.dane.gov.co/laboratorio/serviciosjson/gestion_divipola/municipios.php?vigencia=0
DANE_ALLOWED_HOSTS=www.dane.gov.co,dane.gov.co,geoportal.dane.gov.co,www.datos.gov.co,datos.gov.co
DANE_HTTP_TIMEOUT=20
DANE_MAX_BYTES=5242880

# Factus API Configuration
FACTUS_BASE_URL=https://api-sandbox.factus.com.co
FACTUS_CLIENT_ID=
FACTUS_CLIENT_SECRET=
FACTUS_USERNAME=
FACTUS_PASSWORD=
